{
    "name": "skh6075/delight-rpg-project",
    "type": "project",
    "require": {
        "predis/predis": "^3.3",
        "async-aws/s3": "^2.10",
        "php": "^8.4",
	    "ext-pmmpthread": "*"
	},
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.92"
    },
    "autoload-dev": {
        "psr-4": {
            "alvin0319\\PHPStan\\Rules\\": "phpstan-rules/"
        }
    },
    "license": "MIT",
    "authors": [
        {
            "name": "skh6075",
            "email": "skh6075@gmail.com"
        }
    ],
    "scripts": {
        "lint": "@php vendor/bin/phpstan analyse plugins phpstan-rules --memory-limit=2G",
        "generate-baseline": "@php vendor/bin/phpstan analyse --generate-baseline=phpstan-baseline.neon plugins phpstan-rules",
        "fix": "@php vendor/bin/php-cs-fixer fix plugins"
    }
}
